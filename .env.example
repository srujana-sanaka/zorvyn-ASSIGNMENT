NODE_ENV=development
PORT=4000

# Render/Railway typically provide DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_db

# If DATABASE_URL is not set, the app will use the PG_* variables
PGHOST=localhost
PGPORT=5432
PGDATABASE=finance_db
PGUSER=postgres
PGPASSWORD=postgres

JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=1d

# CORS
CORS_ORIGIN=http://localhost:5173
